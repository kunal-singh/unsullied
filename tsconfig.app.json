{
  "extends": "@kunal-singh/typescript-config/react",
  "compilerOptions": {
    // Vite injects these globals; without this, types like `import.meta.env` are unknown.
    "types": ["vite/client"],

    // Emit only .d.ts — Vite handles JS output via build.lib.
    "emitDeclarationOnly": true,
    // Write declarations to dist so consumers can resolve types from the package root.
    "declarationDir": "./dist",

    // Below: stricter than the preset; kept as explicit opt-ins so intent is clear.
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    // Disallows syntax esbuild can't strip (e.g. const enum, namespace with values).
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    // Prevents importing side-effect files (e.g. CSS) without a type declaration.
    "noUncheckedSideEffectImports": true
  },
  "include": ["src"]
}
